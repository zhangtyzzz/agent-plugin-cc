{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./plugins/agent-bridge/dist",
    "rootDir": "./plugins/agent-bridge/scripts",
    "declaration": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
