{
  "description": "Stop-time review gate — triggers external agent review when Claude Code completes a task",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"${CLAUDE_PLUGIN_ROOT}/scripts/bridge.ts\" --task review --code-file /tmp/uab-stop-review.txt",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
