{
  "description": "Stop-time review gate — triggers external agent review when Claude Code completes a task",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/stop-review-gate.js\"",
            "timeout": 900
          }
        ]
      }
    ]
  }
}
